{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NorvesEditor",
  "version": "0.1.0",
  "identifier": "com.norves.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --filter @norves/editor dev",
    "beforeBuildCommand": "pnpm --filter @norves/editor build"
  },
  "app": {
    "windows": [
      {
        "title": "NorvesEditor",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
